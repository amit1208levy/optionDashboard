<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by Python's interpreter under hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- PyInstaller bundles many third-party dylibs (Qt, matplotlib, etc.)
         that aren't signed by us — disable library validation so they load -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Python uses DYLD_* env vars internally during startup -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
